{
  "name": "silicon-tech-tycoon",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "description": "Silicon: Tech Tycoon \u2014 design and sell tech products. Web build (Vite + React + TS), ships to iOS via Capacitor.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --noEmit",
    "furniture:fetch": "node scripts/fetch-furniture.mjs",
    "assets:icons": "node scripts/gen-icons.mjs",
    "certs:clean": "node scripts/asc-revoke-dev-certs.mjs",
    "shots:stage": "esbuild scripts/stage-save.mjs --bundle --platform=node --format=cjs --outfile=scripts/.stage.cjs --log-level=error && node scripts/.stage.cjs",
    "shots:stage:showcase": "esbuild scripts/stage-showcase.mjs --bundle --platform=node --format=cjs --outfile=scripts/.stage-showcase.cjs --log-level=error && node scripts/.stage-showcase.cjs",
    "shots:features": "node scripts/shots-features.mjs",
    "sim": "esbuild scripts/balance-sim.mjs --bundle --platform=node --format=cjs --outfile=scripts/.sim.cjs --log-level=error && node scripts/.sim.cjs",
    "shots:hero": "node scripts/shots-hero.mjs",
    "shots:store": "node scripts/shots-store.mjs",
    "shots:ipad": "node scripts/shots-ipad.mjs",
    "promo:stage": "esbuild scripts/stage-promo-video.mjs --bundle --platform=node --format=cjs --outfile=scripts/.promo-stage.cjs --log-level=error && node scripts/.promo-stage.cjs",
    "promo:video": "npm run promo:stage && node scripts/promo-video.mjs"
  },
  "dependencies": {
    "@capacitor/core": "^6.2.1",
    "@capacitor/haptics": "^6.0.3",
    "@capacitor/local-notifications": "^6.1.3",
    "@capacitor/preferences": "^6.0.4",
    "@capacitor/splash-screen": "^6.0.4",
    "@capacitor/status-bar": "^6.0.3",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "lucide-react": "^1.17.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "three": "^0.184.0",
    "three-stdlib": "^2.36.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.1",
    "@capacitor/ios": "^6.2.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^4.3.4",
    "playwright-core": "^1.55.0",
    "sharp": "^0.34.5",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8"
  }
}
