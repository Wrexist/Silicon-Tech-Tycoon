default_platform(:ios)

platform :ios do

  desc "Build and upload a new beta to TestFlight"
  lane :beta do
    setup_ci

    api_key = app_store_connect_api_key(
      key_id:        ENV["ASC_KEY_ID"],
      issuer_id:     ENV["ASC_ISSUER_ID"],
      key_content:   ENV["ASC_KEY_P8"],
      in_house:      false,
    )

    # SSH agent is already loaded by the workflow (webfactory/ssh-agent).
    # Match clones ios-certificates via SSH — no username/token needed here.
    match(
      type:      "appstore",
      readonly:  true,
      api_key:   api_key,
      git_url:   ENV["MATCH_GIT_URL"],
    )

    build_app(
      workspace:     "App.xcworkspace",
      scheme:        "App",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "com.wrexist.silicon" => "match AppStore com.wrexist.silicon",
        },
      },
      output_directory: "./build",
      output_name:      "Silicon.ipa",
      clean:            true,
    )

    upload_to_testflight(
      api_key:                           api_key,
      skip_waiting_for_build_processing: true,
    )

    UI.success "✓ Uploaded to TestFlight"
  end

end
